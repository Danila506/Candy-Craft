// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  url      = env("DATABASE_URL")
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String?   @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  phone           String?   @unique
  passwordHash    String
  googleId        String?   @unique
  yandexId        String?   @unique
  vkId            String?   @unique
  role            Role      @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart Cart?

  orders                  Order[]
  addresses               UserAddress[]
  orderStatusChanges      OrderStatusHistory[]     @relation("OrderStatusChangedBy")
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

model EmailVerificationToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model UserAddress {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  label          String?
  country        String   @default("Россия")
  city           String?
  street         String?
  house          String?
  apartment      String?
  entrance       String?
  floor          String?
  intercom       String?
  postalCode     String?  @map("postal_code")
  comment        String?
  recipientName  String?  @map("recipient_name")
  recipientPhone String?  @map("recipient_phone")
  fullAddress    String   @map("full_address")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
  @@map("user_addresses")
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Связи
  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id               Int     @id @default(autoincrement())
  cartId           Int     @map("cart_id")
  productId        Int?    @map("product_id")
  quantity         Int     @default(1)
  customName       String? @map("custom_name")
  customConfig     Json?   @map("custom_config")
  customPreviewUrl String? @map("custom_preview_url")
  customPrice      Int?    @map("custom_price")

  // Связи
  cart    Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Product {
  id          Int       @id @default(autoincrement())
  sku         String    @unique
  slug        String    @unique
  name        String
  description String
  price       Int
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  inStock     Int       @default(0) @map("in_stock")
  reservedQty Int       @default(0) @map("reserved_qty")
  imageUrl    String
  categoryId  Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Связи
  cartItems          CartItem[]
  category           Category            @relation(fields: [categoryId], references: [id])
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]

  @@index([name, categoryId])
  @@index([isActive, deletedAt])
  @@index([inStock, reservedQty])
  @@map("products")
}

enum InventoryMovementType {
  RESERVE
  RELEASE
  OUT
  IN
  ADJUSTMENT
}

model InventoryMovement {
  id        Int                   @id @default(autoincrement())
  productId Int                   @map("product_id")
  orderId   Int?                  @map("order_id")
  type      InventoryMovementType
  quantity  Int
  note      String?
  createdAt DateTime              @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([orderId])
  @@map("inventory_movements")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String
  imageUrl    String
  products    Product[]

  @@map("categories")
}

model Order {
  id                 Int         @id @default(autoincrement())
  userId             Int         @map("user_id")
  publicOrderNumber  String?     @unique @map("public_order_number")
  idempotencyKey     String?     @map("idempotency_key")
  status             OrderStatus @default(PENDING)
  totalPrice         Int         @map("total_price")
  currency           String      @default("RUB")
  subtotalMinor      Int         @default(0) @map("subtotal_minor")
  discountTotalMinor Int         @default(0) @map("discount_total_minor")
  taxTotalMinor      Int         @default(0) @map("tax_total_minor")
  deliveryFeeMinor   Int         @default(0) @map("delivery_fee_minor")
  giftTotalMinor     Int         @default(0) @map("gift_total_minor")
  finalAmountMinor   Int         @default(0) @map("final_amount_minor")
  address            String
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  // Связи
  user               User                 @relation(fields: [userId], references: [id])
  items              OrderItem[]
  orderAddress       OrderAddress?
  payments           Payment[]
  statusHistory      OrderStatusHistory[]
  inventoryMovements InventoryMovement[]

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@map("orders")
}

enum PaymentProvider {
  YOOKASSA
}

enum PaymentStatus {
  PENDING
  WAITING_FOR_CAPTURE
  SUCCEEDED
  CANCELED
  FAILED
}

model Payment {
  id                Int             @id @default(autoincrement())
  orderId           Int             @map("order_id")
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  amountMinor       Int             @map("amount_minor")
  currency          String
  providerPaymentId String?         @unique @map("provider_payment_id")
  idempotencyKey    String?         @unique @map("idempotency_key")
  confirmationUrl   String?         @map("confirmation_url")
  paidAt            DateTime?       @map("paid_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  order         Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attempts      PaymentAttempt[]
  webhookEvents PaymentWebhookEvent[]

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model PaymentAttempt {
  id              Int      @id @default(autoincrement())
  paymentId       Int      @map("payment_id")
  requestPayload  Json?    @map("request_payload")
  responsePayload Json?    @map("response_payload")
  httpStatus      Int?     @map("http_status")
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_attempts")
}

model PaymentWebhookEvent {
  id              Int             @id @default(autoincrement())
  paymentId       Int?            @map("payment_id")
  provider        PaymentProvider
  eventType       String          @map("event_type")
  providerEventId String?         @unique @map("provider_event_id")
  payload         Json
  isProcessed     Boolean         @default(false) @map("is_processed")
  processingError String?         @map("processing_error")
  receivedAt      DateTime        @default(now()) @map("received_at")
  processedAt     DateTime?       @map("processed_at")

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([eventType])
  @@index([receivedAt])
  @@map("payment_webhook_events")
}

model OrderAddress {
  id             Int      @id @default(autoincrement())
  orderId        Int      @unique @map("order_id")
  country        String   @default("Россия")
  city           String?
  street         String?
  house          String?
  apartment      String?
  entrance       String?
  floor          String?
  intercom       String?
  postalCode     String?  @map("postal_code")
  comment        String?
  recipientName  String?  @map("recipient_name")
  recipientPhone String?  @map("recipient_phone")
  fullAddress    String   @map("full_address")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([city])
  @@map("order_addresses")
}

model OrderStatusHistory {
  id              Int          @id @default(autoincrement())
  orderId         Int          @map("order_id")
  fromStatus      OrderStatus? @map("from_status")
  toStatus        OrderStatus  @map("to_status")
  reason          String?
  changedByUserId Int?         @map("changed_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation("OrderStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([createdAt])
  @@index([changedByUserId])
  @@map("order_status_history")
}

enum OrderStatus {
  PENDING // создан
  PAID // оплачен
  PROCESSING // собирается
  SHIPPED // отправлен
  COMPLETED // выполнен
  CANCELED // отменён
}

model OrderItem {
  id          Int    @id @default(autoincrement())
  orderId     Int    @map("order_id")
  productId   Int?   @map("product_id")
  productName String @map("product_name")

  quantity         Int     @default(1)
  price            Int
  customConfig     Json?   @map("custom_config")
  customPreviewUrl String? @map("custom_preview_url")

  // Связи
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}
